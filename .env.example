# =============================================================================
# Copie para .env (dev) ou .env.production (Docker) — UMA variável por linha.
# Nunca commite arquivos .env* com segredos reais.
#
# ERRO COMUM: colar tudo em uma linha ou grudar duas variáveis (ex.: .../dbNAME= e
# na sequência ENCRYPTION_SECRET= sem quebra de linha). Isso quebra o Postgres e o app.
# =============================================================================

NODE_ENV=production
PORT=3333

# --- Postgres (mesmo usuário/senha do DATABASE_URL abaixo) ---
POSTGRES_DB=porthos_gateway
POSTGRES_USER=porthos
POSTGRES_PASSWORD=troque-esta-senha

# Prisma — escolha UMA linha conforme o ambiente:
# Local (npm run dev, sem Docker): host 127.0.0.1 ou localhost
# DATABASE_URL=postgresql://porthos:senha@127.0.0.1:5432/porthos_gateway
# Docker (compose): host do serviço "postgres"
DATABASE_URL=postgresql://porthos:troque-esta-senha@postgres:5432/porthos_gateway

# Redis — local (npm run dev): descomente a linha de baixo e comente a do Docker
# REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=redis://redis:6379

# JWT (Bearer)
JWT_SECRET=troque-por-string-longa-e-aleatoria

# Criptografia das provider keys no banco (32+ bytes recomendado)
ENCRYPTION_SECRET=troque-por-chave-longa-hex-ou-string

# Chaves fallback dos provedores (opcional se o cliente cadastrar provider keys na API)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# POST /admin/maintenance/run — header x-admin-secret
ADMIN_MAINTENANCE_SECRET=troque-este-segredo

# Manutenção agendada (opcional)
MAINTENANCE_SCHEDULER_ENABLED=true
MAINTENANCE_INTERVAL_MINUTES=60
